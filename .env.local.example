# =============================================
# BETTER AUTH
# =============================================
BETTER_AUTH_SECRET=minimum_32_characters_long_random_secret_here
BETTER_AUTH_URL=http://localhost:3000

# =============================================
# GOOGLE OAUTH
# =============================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# =============================================
# DATABASE (Neon PostgreSQL)
# =============================================
# Neon থেকে পাবে — pooled connection
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"

# Neon থেকে পাবে — direct connection (migration এর জন্য)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# =============================================
# APP URL (Vercel deploy করার পর update করো)
# =============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
